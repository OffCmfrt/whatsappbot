        .btn-call { border-color: #4ade80; color: #4ade80; background: rgba(74,222,128,0.05); }
        .btn-call:hover { background: #4ade80; color: #000; }
        .btn-chat { border-color: #25d366; color: #25d366; background: rgba(37,211,102,0.05); }
        .btn-chat:hover { background: #25d366; color: #000; }
        .status-actions {
