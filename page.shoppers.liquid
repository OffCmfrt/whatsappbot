        .status-pill:hover { background: rgba(255,255,255,0.1); color: #fff; border-color: rgba(255,255,255,0.3); }
        .status-pill.active { background: #fff; color: #000; border-color: #fff; box-shadow: 0 0 12px rgba(255,255,255,0.15); }

        /* Card Mobile */
        @media (max-width: 768px) {
            .cards-view .shopper-card {
                padding: 1.25rem;
                border-radius: 16px;
                gap: 1rem;
            }
