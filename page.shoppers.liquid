        /* Inbox Pagination */
        .inbox-pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 0;
            margin-top: 1rem;
        }
        .inbox-pagination .page-info { font-size: 0.85rem; color: rgba(255,255,255,0.5); }

        /* Unread indicator dot */
        .unread-dot {
            width: 8px;
            height: 8px;
            background: #25d366;
            border-radius: 50%;
            display: inline-block;
            margin-right: 0.3rem;
            animation: pulse-dot 2s infinite;
        }
        @keyframes pulse-dot {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        /* Responsive Inbox */
        @media (max-width: 1200px) {
            .inbox-item {
                grid-template-columns: 44px 1fr 0.8fr 100px;
            }
            .inbox-preview,
            .inbox-amount + .inbox-pay-method { display: none; }
