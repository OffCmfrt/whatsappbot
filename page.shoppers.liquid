                </div>
                
                <div class="export-checkbox-group">
                    <input type="checkbox" id="includeCustomerMessage" checked>
                    <label for="includeCustomerMessage">Include Customer Messages</label>
                </div>
                
                <div class="export-checkbox-group">
                    <input type="checkbox" id="includeAddress" checked>
                    <label for="includeAddress">Include Address Details</label>
                </div>
            </div>
            
            <div class="export-btn-row">
                <button class="btn btn-outline" id="cancelExport">Cancel</button>
                <button class="btn btn-primary" id="confirmExport">
                    <img src="{{ 'export-icon.svg' | asset_url }}" width="16" height="16" alt="Export" style="vertical-align: middle; margin-right: 6px;" />
                    Export Now
                </button>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="{{ 'shoppers-app.js' | asset_url }}?v=1712700000"></script>
</body>
