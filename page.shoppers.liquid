                padding: 0.875rem;
                min-height: auto;
                border-radius: 14px;
            }
            .row-status { order: 1; }
            .card-select-checkbox { order: 0; width: 24px; height: 24px; }
            .row-order-info { order: 2; min-width: auto; flex: 1; }
            .row-price { order: 3; min-width: auto; }
            .row-customer { order: 4; width: 100%; min-width: auto; }
            .row-products { order: 5; width: 100%; max-width: none; font-size: 0.8rem; color: #bbb; }
            .row-location { order: 6; width: 100%; max-width: none; font-size: 0.8rem; }
            .row-actions-compact { order: 7; margin-top: 0.25rem; }
            .row-status-pills { order: 8; margin-top: 0.25rem; margin-left: auto; }
            .action-icon-btn { width: 36px; height: 36px; }
            .action-icon-btn svg { width: 16px; height: 16px; }
            .status-pill-mini { width: 32px; height: 32px; font-size: 0.85rem; }
