{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopper Management | OFFCOMFRT</title>
    <!-- Google Fonts: Outfit, Inter, Archivo Narrow -->
    {% # theme-check-disable RemoteAsset %}
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700&family=Inter:wght@400;500;600&family=Archivo+Narrow:wght@400;500;600;700&display=swap" rel="stylesheet">
    {% # theme-check-enable RemoteAsset %}
    <style>
        /* Global Styles */
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: #000;
            color: #fff;
            font-family: 'Inter', sans-serif;
            display: flex;
            flex-direction: column;
        }
        a { color: inherit; text-decoration: none; }
        .btn { cursor: pointer; border: none; padding: 0.6rem 1rem; border-radius: 6px; font-weight: 500; font-family: 'Archivo Narrow', sans-serif; text-transform: uppercase; letter-spacing: 1px; transition: all 0.2s; }
        .btn:hover { transform: translateY(-1px); }
        .btn-primary { background: #fff; color: #000; }
        .btn-primary:hover { background: #e0e0e0; }
        .btn-outline { background: transparent; border: 1px solid #fff; color: #fff; }
        .btn-outline:hover { background: rgba(255,255,255,0.1); }
        .btn-danger { background: #ff4757; color: #fff; border: 1px solid #ff4757; }
        .btn-success { background: #2ed573; color: #000; border: 1px solid #2ed573; }
        .btn-chat { background: #25d366; color: #000; border: none; }
        .btn-chat:hover { background: #128c7e; color: #fff; }
        /* Navigation */
        .premium-nav { background: rgba(20,20,20,0.8); backdrop-filter: blur(12px); padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
        .nav-brand { display: flex; align-items: center; gap: 0.5rem; }
        .nav-brand h1 { margin: 0; font-family: 'Outfit', sans-serif; font-size: 1.8rem; }
        .brand-subtitle { font-size: 0.9rem; opacity: 0.7; }
        .nav-actions { display: flex; gap: 0.5rem; }
        /* Header */
        .page-header { padding: 2rem; background: rgba(255,255,255,0.02); }
        .header-content h2 { margin: 0 0 0.5rem 0; font-family: 'Outfit', sans-serif; }
        .header-content p { margin: 0; opacity: 0.7; font-size: 0.9rem; }
        .stats-overview { display: flex; gap: 1rem; margin-top: 1rem; }
        .stat-box { flex: 1; background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px; text-align: center; transition: all 0.3s; }
        .stat-box:hover { background: rgba(255,255,255,0.08); transform: translateY(-2px); }
        .stat-value { display: block; font-size: 1.5rem; font-weight: 600; font-family: 'Archivo Narrow', sans-serif; }
        .stat-label { font-size: 0.85rem; opacity: 0.8; }
        .text-success { color: #2ed573; }
        .text-warning { color: #ffa502; }
        .text-danger { color: #ff4757; }
        /* ==========================================
           PROFESSIONAL FILTER BAR STYLES
           ========================================== */
        .control-bar { 
            display: flex; 
            flex-direction: column;
            padding: 1.5rem 2.5rem; 
            margin-bottom: 1.5rem; 
            background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            gap: 1.25rem;
        }
        
        /* Filter Section Headers */
        .filter-section-title {
            font-size: 0.65rem;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .filter-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, rgba(255,255,255,0.1) 0%, transparent 100%);
        }
        
        .control-row { 
            display: flex; 
            justify-content: flex-start; 
            align-items: flex-start; 
            gap: 1.5rem; 
            flex-wrap: wrap; 
            width: 100%;
        }
        
        /* Status Tabs - Pill Style */
        .segment-tabs { 
            display: flex; 
            gap: 0.4rem; 
            flex-wrap: wrap; 
            background: rgba(0,0,0,0.3);
            padding: 0.4rem;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.06);
        }
        .segment-tabs .tab { 
            background: transparent; 
            border: none; 
            color: rgba(255,255,255,0.5); 
            padding: 0.5rem 1rem; 
            font-family: 'Archivo Narrow', sans-serif; 
            letter-spacing: 1px; 
            font-weight: 600;
            font-size: 0.75rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            cursor: pointer;
            border-radius: 8px;
            text-transform: uppercase;
        }
        .segment-tabs .tab:hover { 
            color: #fff; 
            background: rgba(255,255,255,0.05);
        }
        .segment-tabs .tab.active { 
            color: #000;
            background: #fff;
            box-shadow: 0 2px 8px rgba(255,255,255,0.15);
        }
        .segment-tabs .tab .tab-count {
            font-size: 0.65rem;
            margin-left: 0.3rem;
            opacity: 0.7;
        }
        
        /* View Toggle */
        .view-toggle-wrapper {
            display: flex;
            align-items: center;
            gap: 0.3rem;
            margin-left: auto;
        }
        .view-toggle-btn {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.15);
            color: rgba(255,255,255,0.6);
            padding: 0.5rem 0.9rem;
            border-radius: 8px;
            font-family: 'Archivo Narrow', sans-serif;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .view-toggle-btn:hover {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border-color: rgba(255,255,255,0.3);
        }
        .view-toggle-btn.active {
            background: #fff;
            color: #000;
            border-color: #fff;
        }
        
        /* Filter Groups */
        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            flex: 1;
            min-width: 280px;
            max-width: 100%;
        }
        
        /* Filter Row Layout */
        .filters-row {
            display: flex;
            gap: 2rem;
            flex-wrap: nowrap;
            align-items: flex-start;
        }
        
        @media (max-width: 1200px) {
            .filters-row {
                flex-direction: column;
                gap: 1rem;
            }
            .filter-group {
                width: 100%;
                max-width: none;
            }
        }
        
        /* Search Box - Enhanced */
        .search-box { 
            position: relative; 
            width: 100%;
            max-width: 350px;
        }
        .search-box input { 
            width: 100%;
            padding: 0.75rem 0.75rem 0.75rem 2.75rem; 
            border-radius: 10px; 
            border: 1px solid rgba(255,255,255,0.08); 
            background: rgba(0,0,0,0.3); 
            color: #fff; 
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }
        .search-box input:focus { 
            border-color: rgba(255,255,255,0.3); 
            background: rgba(0,0,0,0.5); 
            outline: none; 
            box-shadow: 0 0 0 3px rgba(255,255,255,0.05), 0 4px 12px rgba(0,0,0,0.3); 
        }
        .search-box input::placeholder { color: rgba(255,255,255,0.3); }
        .search-box svg { 
            position: absolute; 
            left: 1rem; 
            top: 50%; 
            transform: translateY(-50%); 
            stroke: rgba(255,255,255,0.4); 
            transition: stroke 0.3s; 
        }
        .search-box input:focus + svg { stroke: rgba(255,255,255,0.8); }
        
        /* Date Filter - Compact */
        .date-filter-container {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(0,0,0,0.3);
            padding: 0.4rem;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.06);
        }
        .date-filter input { 
            padding: 0.6rem 0.75rem; 
            border-radius: 6px; 
            border: 1px solid rgba(255,255,255,0.08); 
            background: rgba(255,255,255,0.03); 
            color: #fff; 
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
            width: 130px;
        }
        .date-filter input:focus {
            border-color: rgba(255,255,255,0.2);
            outline: none;
        }
        .date-separator { 
            color: rgba(255,255,255,0.3); 
            font-weight: 300;
            font-size: 0.8rem;
        }
        
        /* Quick Date Filters - Chip Style */
        .quick-date-filters { 
            display: flex; 
            gap: 0.4rem; 
            flex-wrap: wrap; 
            align-items: center; 
        }
        .quick-date-btn {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.5);
            padding: 0.4rem 0.75rem;
            border-radius: 6px;
            font-size: 0.7rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .quick-date-btn:hover { 
            border-color: rgba(255,255,255,0.2); 
            color: #fff; 
            background: rgba(255,255,255,0.06);
        }
        .quick-date-btn.active { 
            background: rgba(255,255,255,0.12); 
            color: #fff; 
            border-color: rgba(255,255,255,0.25);
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        }
        
        /* Advanced Filters Row */
        .advanced-filters {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            align-items: flex-start;
        }
        
        /* Dropdown Filters */
        .filter-dropdown {
            position: relative;
        }
        .filter-dropdown select {
            padding: 0.6rem 2rem 0.6rem 0.75rem;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.08);
            background: rgba(0,0,0,0.3);
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
            cursor: pointer;
            appearance: none;
            min-width: 140px;
        }
        .filter-dropdown::after {
            content: '▼';
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.6rem;
            color: rgba(255,255,255,0.4);
            pointer-events: none;
        }
        .filter-dropdown select:focus {
            border-color: rgba(255,255,255,0.2);
            outline: none;
        }
        .filter-dropdown select option {
            background: #1a1a1a;
            color: #fff;
        }
        
        /* Order ID Range Filter - Compact */
        .order-id-filter { 
            display: flex; 
            align-items: center; 
            gap: 0.5rem; 
            background: rgba(0,0,0,0.3);
            padding: 0.4rem;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.06);
        }
        .order-id-input {
            width: 110px;
            padding: 0.5rem 0.6rem;
            border-radius: 6px;
            border: 1px solid rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.03);
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
        }
        .order-id-input:focus { 
            border-color: rgba(255,255,255,0.2); 
            outline: none; 
        }
        .order-id-input::placeholder { color: rgba(255,255,255,0.3); }
        .order-id-separator { 
            color: rgba(255,255,255,0.3); 
            font-size: 0.75rem;
            text-transform: lowercase;
        }
        .btn-apply-small {
            padding: 0.5rem 0.75rem;
            font-size: 0.7rem;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.15);
            color: #fff;
            border-radius: 6px;
            cursor: pointer;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            transition: all 0.2s;
        }
        .btn-apply-small:hover {
            background: rgba(255,255,255,0.15);
            border-color: rgba(255,255,255,0.25);
        }
        
        /* Clear Filters Button */
        .clear-filters-btn {
            background: rgba(255,71,87,0.08);
            border: 1px solid rgba(255,71,87,0.2);
            color: #ff6b7a;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.7rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }
        .clear-filters-btn:hover { 
            background: rgba(255,71,87,0.15); 
            border-color: rgba(255,71,87,0.35);
            color: #ff4757;
        }
        .clear-filters-btn svg {
            width: 12px;
            height: 12px;
        }
        
        /* Bulk Actions Bar */
        .bulk-actions-bar {
            display: none;
            flex-direction: column;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            background: linear-gradient(90deg, rgba(46,213,115,0.1) 0%, rgba(46,213,115,0.05) 100%);
            border: 1px solid rgba(46,213,115,0.2);
            border-radius: 10px;
            margin-bottom: 1rem;
            animation: slideDown 0.3s ease;
        }
        .bulk-actions-bar.active {
            display: flex;
        }
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .bulk-actions-left, .bulk-actions-right {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }
        .bulk-actions-right {
            border-top: 1px solid rgba(46,213,115,0.15);
            padding-top: 0.75rem;
        }
        .bulk-actions-bar .selected-count {
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            color: #2ed573;
            font-size: 0.9rem;
            min-width: 80px;
        }
        .bulk-actions-bar .bulk-btn {
            padding: 0.4rem 0.8rem;
            border-radius: 6px;
            font-size: 0.7rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
        }
        .bulk-btn-delete {
            background: rgba(255,71,87,0.15);
            color: #ff6b7a;
            border: 1px solid rgba(255,71,87,0.3);
        }
        .bulk-btn-delete:hover {
            background: rgba(255,71,87,0.25);
            color: #ff4757;
        }
        .bulk-btn-status {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.2);
        }
        .bulk-btn-status:hover {
            background: rgba(255,255,255,0.15);
        }
        .bulk-btn-select-all {
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.8);
            border: 1px solid rgba(255,255,255,0.15);
        }
        .bulk-btn-select-all:hover {
            background: rgba(255,255,255,0.12);
            color: #fff;
            border-color: rgba(255,255,255,0.25);
        }
        .bulk-btn-select-all.active {
            background: rgba(46,213,115,0.2);
            color: #2ed573;
            border-color: rgba(46,213,115,0.4);
        }
        .bulk-btn-close {
            background: transparent;
            color: rgba(255,255,255,0.5);
            border: none;
            margin-left: auto;
            font-size: 1.2rem;
            cursor: pointer;
            padding: 0.2rem;
        }
        .bulk-btn-close:hover { color: #fff; }
        
        /* Export Modal */
        #exportModal { display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.9); backdrop-filter: blur(10px); z-index: 1500; justify-content: center; align-items: center; }
        #exportModal.active { display: flex; }
        .export-modal-content { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.2); padding: 2rem; border-radius: 12px; width: 90%; max-width: 500px; max-height: 90vh; overflow-y: auto; }
        .export-modal-content h3 { margin-top: 0; font-family: 'Outfit', sans-serif; margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: 2px; }
        .export-options { display: grid; gap: 1rem; }
        .export-option-group label { display: block; font-size: 0.75rem; color: #888; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px; font-family: 'Archivo Narrow', sans-serif; }
        .export-option-group select, .export-option-group input {
            width: 100%;
            padding: 0.7rem;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 6px;
            color: #fff;
            font-family: 'Inter', sans-serif;
        }
        .export-option-group select:focus, .export-option-group input:focus { outline: none; border-color: #fff; }
        .export-checkbox-group { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem; }
        .export-checkbox-group input[type="checkbox"] { width: 18px; height: 18px; accent-color: #fff; }
        .export-checkbox-group label { font-size: 0.85rem; color: #ccc; cursor: pointer; }
        .export-btn-row { display: flex; gap: 1rem; margin-top: 2rem; }
        .export-btn-row button { flex: 1; padding: 0.8rem; }
        
        /* Filter Label */
        .filter-label {
            font-size: 0.7rem;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Archivo Narrow', sans-serif;
            margin-right: 0.5rem;
        }
        /* Shoppers List (Horizontal Rows) */
        .shoppers-grid {
            display: flex;
            flex-direction: column;
            padding: 0 2.5rem;
            gap: 0.6rem;
            margin-bottom: 3rem;
        }
        @media (max-width: 768px) {
            .shoppers-grid { padding: 0 0.75rem; gap: 0.5rem; }
        }

        @keyframes staggeredFadeIn {
            from { opacity: 0; transform: translateX(-10px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .shopper-card {
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 1rem 1.25rem;
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 1rem;
            transition: all 0.25s ease;
            position: relative;
            animation: staggeredFadeIn 0.4s ease both;
            animation-delay: calc(var(--index, 0) * 0.02s);
            min-height: 72px;
        }
        .shopper-card:hover {
            background: rgba(255,255,255,0.06);
            border-color: rgba(255,255,255,0.25);
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }
        .shopper-card.has-message { border-left: 3px solid #25d366; }
        .shopper-card.status-confirmed { border-left: 3px solid #2ed573; }
        .shopper-card.status-cancelled { border-left: 3px solid #ff4757; }
        .shopper-card.status-edit_details { border-left: 3px solid #ffa502; }

        /* Card Selection */
        .shopper-card.selected {
            border-color: #2ed573;
            background: rgba(46,213,115,0.08);
            box-shadow: 0 0 0 1px rgba(46,213,115,0.4);
        }
        .card-select-checkbox {
            width: 22px;
            height: 22px;
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 6px;
            background: rgba(0,0,0,0.3);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            flex-shrink: 0;
        }
        .card-select-checkbox:hover {
            border-color: rgba(255,255,255,0.6);
        }
        .card-select-checkbox.checked {
            background: #2ed573;
            border-color: #2ed573;
        }
        .card-select-checkbox.checked::after {
            content: '✓';
            color: #000;
            font-size: 13px;
            font-weight: bold;
        }
        .card-select-hint { display: none; }

        /* Row Layout Elements */
        .row-status { flex-shrink: 0; }
        .row-order-info { min-width: 110px; flex-shrink: 0; }
        .row-order-info .order-id-small { font-size: 0.85rem; color: #fff; font-weight: 700; margin-bottom: 0.15rem; font-family: 'Inter', monospace; letter-spacing: 0.5px; }
        .row-order-info .timestamp-row { font-size: 0.72rem; color: #777; margin-top: 0.15rem; }
        .row-customer { flex: 1; min-width: 160px; }
        .row-customer .customer-name-big { font-family: 'Archivo Narrow', sans-serif; font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0 0 0.2rem 0; letter-spacing: 0.3px; text-transform: none; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .row-customer .customer-meta { font-size: 0.78rem; color: #aaa; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .row-products { flex: 1.2; min-width: 120px; max-width: 280px; font-size: 0.82rem; color: #ccc; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .row-location { font-size: 0.82rem; color: #888; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 140px; min-width: 90px; }
        .row-price { text-align: right; min-width: 80px; flex-shrink: 0; }
        .row-price .price-big { font-size: 1.1rem; font-family: 'Archivo Narrow', sans-serif; font-weight: 700; color: #fff; line-height: 1.2; }
        .row-price .pay-method-badge { font-size: 0.7rem; color: #888; }

        /* Compact Action Icons */
        .row-actions-compact { display: flex; gap: 0.35rem; flex-shrink: 0; }
        .action-icon-btn {
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.2);
            background: transparent;
            color: #fff;
            cursor: pointer;
            transition: all 0.2s;
            padding: 0;
