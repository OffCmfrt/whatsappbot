        /* Status Badges */
        .badge { font-family: 'Archivo Narrow', sans-serif; font-size: 0.68rem; padding: 0.2rem 0.5rem; border-radius: 6px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
        .badge-status.confirmed { background: #2ed573; color: #000; }
        .badge-status.cancelled { background: #ff4757; color: #fff; }
        .badge-status.edit_details { background: #ffa502; color: #000; }
        .badge-status.pending { background: #666; color: #fff; }

        /* Responsive Row */
        @media (max-width: 1100px) {
            .shopper-card { flex-wrap: wrap; gap: 0.5rem 0.75rem; padding: 0.875rem 1rem; }
            .row-products, .row-location { width: 100%; max-width: none; order: 5; }
        }
        @media (max-width: 768px) {
            .shopper-card {
                flex-wrap: wrap;
