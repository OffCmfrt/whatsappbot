        .action-icon-btn:hover { background: #fff; color: #000; border-color: #fff; }
        .action-icon-btn svg { width: 16px; height: 16px; }
        .btn-call-icon { border-color: rgba(74,222,128,0.4); color: #4ade80; }
        .btn-call-icon:hover { background: #4ade80; color: #000; }

        /* Mini Status Pills */
        .row-status-pills { display: flex; gap: 0.35rem; flex-shrink: 0; }
        .status-pill-mini {
            width: 34px;
            height: 34px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.15);
