        /* Clear Filters */
        .mo-clear-btn {
            background: rgba(255,71,87,0.06);
            border: 1px solid rgba(255,71,87,0.2);
            color: #ff6b7a;
            padding: 0.45rem 0.9rem;
            border-radius: 6px;
            font-size: 0.68rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
