            border-radius: 20px;
            padding: 1.75rem;
            gap: 1.25rem;
            min-height: auto;
            background: linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.015) 100%);
            border: 1px solid rgba(255,255,255,0.12);
