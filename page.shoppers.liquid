            .inbox-content {
                padding: 1rem;
            }
            .inbox-item {
                grid-template-columns: 40px 1fr 80px;
                gap: 0.5rem;
                padding: 0.75rem;
            }
            .inbox-amount, .inbox-time, .inbox-actions { display: none; }
        }

        /* Responsive Analytics */
        @media (max-width: 1200px) {
            .analytics-stats-row {
                grid-template-columns: repeat(3, 1fr);
            }
