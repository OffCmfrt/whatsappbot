        /* Edit Modal */
        #editModal { display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.9); backdrop-filter: blur(10px); z-index: 1000; justify-content: center; align-items: center; }
        #editModal.active { display: flex; }
        .modal-content { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.2); padding: 2.5rem; border-radius: 12px; width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto; box-shadow: 0 15px 40px rgba(0,0,0,0.8); }
        .modal-content h3 { margin-top: 0; font-family: 'Outfit', sans-serif; margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: 2px; }
        .form-group { margin-bottom: 1rem; text-align: left; }
        .form-group label { display: block; font-size: 0.8rem; font-family: 'Archivo Narrow', sans-serif; color: #fff; margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 1px; }
        .form-group input, .form-group textarea { width: 100%; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.2); border-radius: 6px; color: #fff; box-sizing: border-box; font-family: 'Inter', sans-serif; transition: border-color 0.2s; }
        .form-group input:focus, .form-group textarea:focus { outline: none; border-color: #fff; }
        .form-group textarea { resize: vertical; min-height: 80px; }
        
        /* Customer Message in Edit Modal */
        .customer-message-box {
            background: rgba(37, 211, 102, 0.1);
            border: 1px solid rgba(37, 211, 102, 0.3);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1.5rem;
        }
        .customer-message-box .msg-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;
        }
        .customer-message-box .msg-header span {
            font-size: 0.75rem;
            color: #25d366;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .customer-message-box .msg-content {
            font-size: 0.9rem;
            color: #fff;
            line-height: 1.5;
            white-space: pre-wrap;
        }
        
        /* Product Editor */
        #productEditor { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1rem; margin-top: 1rem; }
        .product-item-row { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; align-items: center; }
        .product-item-row input[type="text"] { flex: 2; font-size: 0.85rem; padding: 0.5rem; }
        .product-item-row input[type="text"].item-size { flex: 0 0 80px; font-size: 0.85rem; padding: 0.5rem; text-align: center; }
        .product-item-row input[type="number"] { width: 60px; font-size: 0.85rem; padding: 0.5rem; }
        .btn-remove-item { background: none; border: 1px solid rgba(255,0,0,0.3); color: #ff4757; border-radius: 4px; padding: 0.4rem; cursor: pointer; }
        .btn-remove-item:hover { background: rgba(255,0,0,0.1); }
        .btn-add-item { width: 100%; background: transparent; border: 1px dashed rgba(255,255,255,0.2); color: #aaa; padding: 0.5rem; border-radius: 6px; cursor: pointer; font-size: 0.8rem; margin-top: 0.5rem; }
        .btn-add-item:hover { border-color: #fff; color: #fff; }

        .modal-actions { display: flex; gap: 1rem; margin-top: 2rem; }
        .modal-actions button { flex: 1; height: 44px; }

        /* Live Chat Modal */
        #chatModal { display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.95); backdrop-filter: blur(10px); z-index: 3000; }
        #chatModal.active { display: flex; }
        .chat-container { display: flex; width: 100%; height: 100%; }
        .chat-sidebar { width: 300px; background: #0a0a0a; border-right: 1px solid rgba(255,255,255,0.1); padding: 1.5rem; display: flex; flex-direction: column; }
        .chat-sidebar h3 { margin: 0 0 1rem 0; font-family: 'Outfit', sans-serif; font-size: 1.2rem; }
        .chat-customer-info { padding: 1rem; background: rgba(255,255,255,0.05); border-radius: 8px; margin-bottom: 1rem; }
        .chat-customer-info .info-row { display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.85rem; }
        .chat-customer-info .info-label { color: #888; }
        .chat-customer-info .info-value { color: #fff; font-weight: 500; }
        .chat-main { flex: 1; display: flex; flex-direction: column; background: #080808; }
        .chat-header { padding: 0.75rem 1.5rem; background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: center; }
        .chat-header h4 { margin: 0; font-family: 'Outfit', sans-serif; font-size: 0.95rem; font-weight: 500; }
        .chat-messages { flex: 1; overflow-y: auto; padding: 1rem 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; background: #0b0b0b; }
        .chat-date-separator { display: flex; align-items: center; justify-content: center; margin: 0.8rem 0; }
        .chat-date-separator span { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); font-size: 0.7rem; padding: 0.3rem 0.8rem; border-radius: 6px; letter-spacing: 0.5px; font-weight: 500; }
        .chat-message { display: flex; max-width: 72%; animation: msgFadeIn 0.15s ease; }
        .chat-message.customer { align-self: flex-start; }
        .chat-message.agent { align-self: flex-end; }
        
        /* Unread message styling */
        .chat-message.unread-message .msg-bubble {
            border-left: 3px solid #00a884;
            background: rgba(0, 168, 132, 0.15);
        }
        .unread-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            background: #00a884;
            border-radius: 50%;
            margin-right: 4px;
            animation: unreadPulse 2s ease-in-out infinite;
        }
        @keyframes unreadPulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(1.2); }
        }
        
        .msg-bubble { padding: 0.55rem 0.85rem; border-radius: 10px; font-size: 0.875rem; line-height: 1.45; position: relative; }
        .chat-message.customer .msg-bubble { background: rgba(255,255,255,0.08); border-bottom-left-radius: 3px; color: #e8e8e8; }
        .chat-message.agent .msg-bubble { background: #005c4b; border-bottom-right-radius: 3px; color: #e8f5e9; }
        .msg-content { word-break: break-word; white-space: pre-wrap; }
        .msg-meta { display: flex; align-items: center; gap: 0.35rem; justify-content: flex-end; margin-top: 0.2rem; }
        .msg-time { font-size: 0.65rem; opacity: 0.6; }
        .msg-type-badge { font-size: 0.55rem; background: rgba(255,255,255,0.12); padding: 0.1rem 0.35rem; border-radius: 3px; opacity: 0.7; letter-spacing: 0.3px; text-transform: uppercase; font-weight: 600; }
        
        /* WhatsApp-style message status indicators */
        .msg-status { font-size: 0.7rem; font-weight: 500; line-height: 1; }
        .msg-status-sent { color: rgba(255,255,255,0.5); }
        .msg-status-delivered { color: rgba(255,255,255,0.6); }
        .msg-status-read { color: #53bdeb; }
        .msg-status-failed { color: #ff4757; font-weight: 700; }
        
        .msg-error { font-size: 0.65rem; color: #ff4757; font-weight: 500; }
        .chat-message.msg-failed .msg-bubble { border: 1px solid rgba(255,71,87,0.3); }
        .chat-empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: #555; gap: 0.5rem; }
        .chat-empty-state svg { opacity: 0.3; }
        .chat-empty-text { font-size: 0.9rem; font-weight: 500; }
        .chat-empty-sub { font-size: 0.75rem; opacity: 0.5; }
        @keyframes msgFadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
        .chat-input-area { padding: 0.75rem 1.5rem; background: rgba(255,255,255,0.04); border-top: 1px solid rgba(255,255,255,0.08); display: flex; gap: 0.5rem; align-items: flex-end; }
        .chat-input-area textarea { flex: 1; padding: 0.6rem 0.85rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 10px; color: #fff; font-family: 'Inter', sans-serif; font-size: 0.875rem; resize: none; height: 44px; min-height: 44px; max-height: 120px; line-height: 1.4; }
        .chat-input-area textarea:focus { outline: none; border-color: #005c4b; background: rgba(255,255,255,0.08); }
        .chat-input-area textarea::placeholder { color: rgba(255,255,255,0.3); }
        .chat-input-area button { padding: 0 1.5rem; height: 44px; background: #005c4b; border: none; color: #e8f5e9; border-radius: 10px; font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: background 0.2s; }
        .chat-input-area button:hover { background: #00735e; }
        .chat-close { background: none; border: none; color: #fff; font-size: 1.5rem; cursor: pointer; opacity: 0.7; transition: opacity 0.2s; }
        .chat-close:hover { opacity: 1; }
        .chat-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: #555; gap: 0.5rem; }

        /* Pagination */
        .pagination { display: flex; justify-content: space-between; align-items: center; padding: 1rem 2rem; border-top: 1px solid rgba(255,255,255,0.1); margin-top: 2rem; }
        .page-controls .btn { margin-left: 0.5rem; }
        /* Loading Spinner */
        .table-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 200px; width: 100%; }
        .spinner { border: 3px solid rgba(255,255,255,0.1); border-top: 3px solid #fff; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin-bottom: 1rem; }
        @keyframes spin { to { transform: rotate(360deg); } }
        @media (max-width: 768px) {
            .stats-overview, .control-bar { flex-direction: column; align-items: stretch; }
            .segment-tabs { margin-bottom: 0.5rem; }
            .chat-sidebar { display: none; }
        }

        /* ==========================================
           ANALYTICS DASHBOARD STYLES
           ========================================== */
        .analytics-header {
            position: sticky;
            top: 0;
            background: rgba(10, 10, 10, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 10;
        }
        .analytics-header-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }
        .analytics-header-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .analytics-date-filter {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .analytics-date-filter input[type="date"] {
            padding: 0.5rem 0.8rem;
            border-radius: 6px;
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.05);
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 0.85rem;
        }
        .analytics-date-filter #applyAnalyticsDate {
            background: #fff;
            color: #000;
            border: 1px solid #fff;
            padding: 0.5rem 1.2rem;
            border-radius: 6px;
            font-family: 'Archivo Narrow', sans-serif;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 2px 8px rgba(255,255,255,0.1);
        }
        .analytics-date-filter #applyAnalyticsDate:hover {
            background: #e0e0e0;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(255,255,255,0.15);
        }
        .analytics-date-filter #applyAnalyticsDate:active {
            transform: translateY(0);
            box-shadow: 0 2px 4px rgba(255,255,255,0.1);
        }
        
        /* Analytics Filter Section */
        .analytics-filter-section {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            align-items: flex-end;
        }
        
        /* Quick Filter Buttons */
        .analytics-quick-filters {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }
        .quick-filter-btn {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.6);
            padding: 0.4rem 0.9rem;
            border-radius: 20px;
            font-family: 'Archivo Narrow', sans-serif;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s ease;
            white-space: nowrap;
        }
        .quick-filter-btn:hover {
            background: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.2);
            color: #fff;
        }
        .quick-filter-btn.active {
            background: #fff;
            border-color: #fff;
            color: #000;
            box-shadow: 0 2px 8px rgba(255,255,255,0.2);
        }
        .analytics-content {
            padding: 2rem;
            max-width: 1600px;
            margin: 0 auto;
        }

        /* Stats Row */
        .analytics-stats-row {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 1rem;
            margin-bottom: 2rem;
        }
        .analytics-stat-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            transition: all 0.3s ease;
        }
        .analytics-stat-card:hover {
            transform: translateY(-2px);
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.15);
        }
        .analytics-stat-card .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.08);
        }
        .analytics-stat-card.total .stat-icon { color: #fff; }
        .analytics-stat-card.confirmed .stat-icon { background: rgba(46, 213, 115, 0.15); color: #2ed573; }
        .analytics-stat-card.pending .stat-icon { background: rgba(255, 165, 2, 0.15); color: #ffa502; }
        .analytics-stat-card.cancelled .stat-icon { background: rgba(255, 71, 87, 0.15); color: #ff4757; }
        .analytics-stat-card.edits .stat-icon { background: rgba(83, 189, 235, 0.15); color: #53bdeb; }
        .analytics-stat-card .stat-info {
            display: flex;
            flex-direction: column;
        }
        .analytics-stat-card .stat-number {
            font-size: 1.8rem;
            font-weight: 700;
            font-family: 'Archivo Narrow', sans-serif;
            color: #fff;
            line-height: 1;
        }
        .analytics-stat-card .stat-label {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.6);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 0.25rem;
        }
        .analytics-stat-card .stat-percent {
            font-size: 0.85rem;
            font-weight: 600;
            margin-top: 0.25rem;
        }
        .analytics-stat-card.confirmed .stat-percent { color: #2ed573; }
        .analytics-stat-card.pending .stat-percent { color: #ffa502; }
        .analytics-stat-card.cancelled .stat-percent { color: #ff4757; }
        .analytics-stat-card.edits .stat-percent { color: #53bdeb; }

        /* Charts Grid */
        .analytics-charts-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .analytics-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 1.5rem;
        }
        .analytics-card.wide {
            grid-column: span 1;
        }
        .analytics-card-title {
            margin: 0 0 1.5rem 0;
            font-family: 'Archivo Narrow', sans-serif;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,0.8);
        }

        /* Circular Charts */
        .circular-charts-container {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }
        .circular-chart-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
        }
        .circular-chart {
            width: 100px;
            height: 100px;
            transform: rotate(-90deg);
        }
        .circular-chart-bg {
            fill: none;
            stroke: rgba(255,255,255,0.1);
            stroke-width: 8;
        }
        .circular-chart-progress {
            fill: none;
            stroke-width: 8;
            stroke-linecap: round;
            stroke-dasharray: 283;
            stroke-dashoffset: 283;
            transition: stroke-dashoffset 1.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .circular-chart-progress.confirmed { stroke: #2ed573; }
        .circular-chart-progress.pending { stroke: #ffa502; }
        .circular-chart-progress.cancelled { stroke: #ff4757; }
        .circular-chart-progress.edits { stroke: #53bdeb; }
        .circular-chart-value {
            position: absolute;
            top: 35px;
            font-size: 1.2rem;
            font-weight: 700;
            font-family: 'Archivo Narrow', sans-serif;
        }
        .circular-chart-label {
            margin-top: 0.5rem;
            font-size: 0.75rem;
            color: rgba(255,255,255,0.6);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Bar Chart */
        .bar-chart-container {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            height: 200px;
            gap: 0.5rem;
            padding: 1rem 0;
        }
        .bar-chart-item {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
        }
        .bar-chart-bar-wrapper {
            width: 100%;
            height: 160px;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            position: relative;
        }
        .bar-chart-bar {
            width: 80%;
            background: linear-gradient(to top, rgba(255,255,255,0.3), rgba(255,255,255,0.6));
            border-radius: 4px 4px 0 0;
            transition: height 1s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            min-height: 4px;
        }
        .bar-chart-bar::after {
            content: attr(data-value);
            position: absolute;
            top: -20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.7rem;
            color: rgba(255,255,255,0.8);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .bar-chart-item:hover .bar-chart-bar::after {
            opacity: 1;
        }
        .bar-chart-label {
            font-size: 0.65rem;
            color: rgba(255,255,255,0.5);
            text-align: center;
            transform: rotate(-45deg);
            transform-origin: center;
            white-space: nowrap;
        }

        /* Trend Chart */
        .trend-chart-container {
            position: relative;
            height: 200px;
            padding: 1rem 0;
        }
        .trend-chart-container svg {
            width: 100%;
            height: 100%;
        }
        .trend-line {
            fill: none;
            stroke: #2ed573;
            stroke-width: 3;
            stroke-linecap: round;
            stroke-linejoin: round;
            stroke-dasharray: 2000;
            stroke-dashoffset: 2000;
            animation: drawLine 2s ease forwards;
        }
        @keyframes drawLine {
            to { stroke-dashoffset: 0; }
        }
        .trend-area {
            fill: url(#trendGradient);
            opacity: 0.3;
        }
        .trend-dot {
            fill: #2ed573;
            stroke: #000;
            stroke-width: 2;
            r: 5;
            opacity: 0;
            animation: fadeInDot 0.3s ease forwards;
        }
        .trend-chart-labels {
            display: flex;
            justify-content: space-between;
            padding: 0.5rem 1rem 0;
            font-size: 0.7rem;
            color: rgba(255,255,255,0.4);
        }
        @keyframes fadeInDot {
            to { opacity: 1; }
        }

        /* Analytics Table */
        .analytics-table-container {
            overflow-x: auto;
        }
        .analytics-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }
        .analytics-table th {
            text-align: left;
            padding: 0.75rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.6);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.7rem;
            font-family: 'Archivo Narrow', sans-serif;
        }
        .analytics-table td {
            padding: 0.75rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.9);
        }
        .analytics-table tr:hover td {
            background: rgba(255,255,255,0.03);
        }
        .analytics-table .status-count {
            font-weight: 600;
        }
        .analytics-table .status-count.confirmed { color: #2ed573; }
        .analytics-table .status-count.pending { color: #ffa502; }
        .analytics-table .status-count.cancelled { color: #ff4757; }
        .analytics-table .status-count.edits { color: #53bdeb; }
        .analytics-table .status-pct {
            font-size: 0.75rem;
            opacity: 0.6;
            font-weight: 400;
            margin-left: 4px;
        }
        
        /* Download button for each day */
        .btn-download-day {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.7);
            padding: 6px 10px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .btn-download-day:hover {
            background: rgba(46, 213, 115, 0.15);
            border-color: rgba(46, 213, 115, 0.3);
            color: #2ed573;
            transform: translateY(-1px);
        }
        .btn-download-day svg {
            transition: transform 0.2s ease;
        }
        .btn-download-day:hover svg {
            transform: translateY(1px);
        }
        
        /* Day action buttons container */
        .day-actions {
            display: flex;
            gap: 6px;
            align-items: center;
        }
        .day-actions .btn-download-day {
            padding: 5px 8px;
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            gap: 4px;
        }
        .day-actions .btn-download-day span {
            font-family: 'Archivo Narrow', sans-serif;
        }
        
        /* Confirmed download button - green */
        .btn-download-confirmed:hover {
            background: rgba(46, 213, 115, 0.15) !important;
            border-color: rgba(46, 213, 115, 0.4) !important;
            color: #2ed573 !important;
        }
        
        /* Cancelled download button - red */
        .btn-download-cancelled:hover {
            background: rgba(255, 71, 87, 0.15) !important;
            border-color: rgba(255, 71, 87, 0.4) !important;
            color: #ff4757 !important;
        }
        
        /* Edit download button - cyan */
        .btn-download-edit:hover {
            background: rgba(56, 212, 255, 0.15) !important;
            border-color: rgba(56, 212, 255, 0.4) !important;
            color: #38d4ff !important;
        }
        
        /* Show More button */
        .show-more-row {
            background: rgba(255,255,255,0.01);
        }
        .show-more-row:hover {
            background: rgba(255,255,255,0.02);
        }
        .btn-show-more {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.15);
            color: rgba(255,255,255,0.6);
            padding: 0.6rem 1.2rem;
            border-radius: 6px;
            cursor: pointer;
            font-family: 'Archivo Narrow', sans-serif;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
        }
        .btn-show-more:hover {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.3);
        }

        /* ==========================================
           FOLLOW-UP SYSTEM STYLES
           ========================================== */
        /* Note: follow-up-view uses inline style for display:none;position:fixed etc. - same pattern as analytics/multiOrders/inbox */
        
        .follow-up-header {
            position: sticky;
            top: 0;
            background: rgba(10, 10, 10, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,165,2,0.2);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 10;
        }
        .follow-up-header-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }
        .follow-up-header-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .follow-up-content {
            padding: 2rem;
            max-width: 1600px;
            margin: 0 auto;
        }
        
        /* Campaign Cards */
        .campaigns-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        .campaign-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 1.5rem;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .campaign-card:hover {
            transform: translateY(-2px);
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,165,2,0.3);
        }
        .campaign-card.running {
            border-color: rgba(46,213,115,0.3);
            box-shadow: 0 0 20px rgba(46,213,115,0.1);
        }
        .campaign-card.paused {
            border-color: rgba(255,165,2,0.3);
        }
        .campaign-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }
        .campaign-name {
            font-size: 1.1rem;
            font-weight: 600;
            margin: 0;
            color: #fff;
        }
        .campaign-status {
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .campaign-status.draft { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.7); }
        .campaign-status.running { background: rgba(46,213,115,0.15); color: #2ed573; }
        .campaign-status.paused { background: rgba(255,165,2,0.15); color: #ffa502; }
        .campaign-status.completed { background: rgba(83,189,235,0.15); color: #53bdeb; }
        
        .campaign-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin: 1rem 0;
            padding: 1rem 0;
            border-top: 1px solid rgba(255,255,255,0.05);
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .campaign-stat {
            text-align: center;
        }
        .campaign-stat-value {
            font-size: 1.3rem;
            font-weight: 700;
            font-family: 'Archivo Narrow', sans-serif;
            color: #fff;
        }
        .campaign-stat-label {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.5);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .campaign-actions {
            display: flex;
            gap: 0.5rem;
        }
        .campaign-btn {
            flex: 1;
            padding: 0.5rem;
            border-radius: 6px;
            font-size: 0.75rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
        }
        .campaign-btn-primary {
            background: #ffa502;
            color: #000;
        }
        .campaign-btn-primary:hover {
            background: #ff9500;
        }
        .campaign-btn-outline {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
        }
        .campaign-btn-outline:hover {
            background: rgba(255,255,255,0.1);
        }
        
        /* Campaign Wizard Modal */
        .campaign-wizard {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.9);
            backdrop-filter: blur(8px);
            z-index: 1000;
            overflow-y: auto;
        }
        .campaign-wizard.active { display: block; }
        .wizard-content {
            max-width: 900px;
            margin: 2rem auto;
            background: #111;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            overflow: hidden;
        }
        .wizard-header {
            background: linear-gradient(90deg, rgba(255,165,2,0.1) 0%, transparent 100%);
            padding: 1.5rem 2rem;
            border-bottom: 1px solid rgba(255,165,2,0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .wizard-header h2 {
            margin: 0;
            font-family: 'Outfit', sans-serif;
            color: #ffa502;
        }
        .wizard-close {
            background: none;
            border: none;
            color: rgba(255,255,255,0.6);
            font-size: 1.5rem;
            cursor: pointer;
            padding: 0.5rem;
            transition: color 0.2s;
        }
        .wizard-close:hover { color: #fff; }
        
        .wizard-body {
            padding: 2rem;
        }
        .wizard-step {
            display: none;
        }
        .wizard-step.active { display: block; }
        
        .step-indicator {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-bottom: 2rem;
        }
        .step-dot {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            color: rgba(255,255,255,0.5);
            border: 2px solid transparent;
            transition: all 0.3s;
        }
        .step-dot.active {
            background: rgba(255,165,2,0.2);
            color: #ffa502;
            border-color: #ffa502;
        }
        .step-dot.completed {
            background: rgba(46,213,115,0.2);
            color: #2ed573;
            border-color: #2ed573;
        }
        
        /* Recipient Selection Tabs */
        .recipient-tabs {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding-bottom: 1rem;
        }
        .recipient-tab {
            padding: 0.6rem 1.2rem;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: rgba(255,255,255,0.7);
            font-family: 'Archivo Narrow', sans-serif;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }
        .recipient-tab:hover {
            background: rgba(255,255,255,0.1);
        }
        .recipient-tab.active {
            background: rgba(255,165,2,0.15);
            border-color: rgba(255,165,2,0.3);
            color: #ffa502;
        }
        
        .recipient-tab-content {
            display: none;
        }
        .recipient-tab-content.active { display: block; }
        
        /* Pending Shoppers Table in Wizard */
        .pending-shoppers-table {
            max-height: 400px;
            overflow-y: auto;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
        }
        .pending-shoppers-table table {
            width: 100%;
            border-collapse: collapse;
        }
        .pending-shoppers-table th {
            background: rgba(255,255,255,0.05);
            padding: 0.75rem;
            text-align: left;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255,255,255,0.6);
            font-weight: 600;
            position: sticky;
            top: 0;
        }
        .pending-shoppers-table td {
            padding: 0.75rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.9);
        }
        .pending-shoppers-table tr:hover td {
            background: rgba(255,255,255,0.03);
        }
        
        /* File Upload Area */
        .file-upload-area {
            border: 2px dashed rgba(255,255,255,0.2);
            border-radius: 12px;
            padding: 3rem 2rem;
            text-align: center;
            transition: all 0.3s;
        }
        .file-upload-area:hover {
            border-color: rgba(255,165,2,0.4);
            background: rgba(255,165,2,0.05);
        }
        .file-upload-area input[type="file"] {
            display: none;
        }
        .file-upload-btn {
            background: rgba(255,165,2,0.1);
            border: 1px solid rgba(255,165,2,0.3);
            color: #ffa502;
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-family: 'Archivo Narrow', sans-serif;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }
        .file-upload-btn:hover {
            background: rgba(255,165,2,0.2);
        }
        
        /* Wizard Footer */
        .wizard-footer {
            display: flex;
            justify-content: space-between;
            padding: 1.5rem 2rem;
            border-top: 1px solid rgba(255,255,255,0.1);
            background: rgba(0,0,0,0.3);
        }
        .wizard-btn {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-family: 'Archivo Narrow', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
        }
        .wizard-btn-secondary {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }
        .wizard-btn-secondary:hover {
            background: rgba(255,255,255,0.15);
        }
        .wizard-btn-primary {
            background: #ffa502;
            color: #000;
        }
        .wizard-btn-primary:hover {
            background: #ff9500;
        }
        .wizard-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
            color: #fff;
        }

        /* ==========================================
           INBOX VIEW - Full Page (Unread & Confirmed)
           ========================================== */
        /* Note: inbox-view uses inline style for display:none;position:fixed etc. - same pattern as analytics/multiOrders */

        .inbox-header {
            position: sticky;
            top: 0;
            background: rgba(10, 10, 10, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 10;
        }
        .inbox-header-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }
        .inbox-header-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        /* Inbox Tabs */
        .inbox-tabs {
            display: flex;
            gap: 0.4rem;
            background: rgba(0,0,0,0.3);
            padding: 0.4rem;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.06);
        }
        .inbox-tabs .inbox-tab {
            background: transparent;
            border: none;
            color: rgba(255,255,255,0.5);
            padding: 0.6rem 1.2rem;
            font-family: 'Archivo Narrow', sans-serif;
            letter-spacing: 1px;
            font-weight: 600;
            font-size: 0.8rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            cursor: pointer;
            border-radius: 8px;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .inbox-tabs .inbox-tab:hover { color: #fff; background: rgba(255,255,255,0.05); }
        .inbox-tabs .inbox-tab.active {
            color: #000;
            background: #25d366;
            box-shadow: 0 2px 8px rgba(37, 211, 102, 0.15);
        }
        .inbox-tabs .inbox-tab.active.confirmed-tab {
            background: #2ed573;
        }
        .inbox-tab-count {
            font-size: 0.65rem;
            background: rgba(255,255,255,0.15);
            padding: 0.1rem 0.45rem;
            border-radius: 10px;
            font-weight: 700;
            min-width: 18px;
            text-align: center;
        }
        .inbox-tabs .inbox-tab.active .inbox-tab-count {
            background: rgba(0,0,0,0.2);
            color: #000;
        }

        /* Inbox Content */
        .inbox-content {
            padding: 2rem;
            max-width: 1600px;
            margin: 0 auto;
        }

        /* Inbox Stats Row */
        .inbox-stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            margin-bottom: 2rem;
        }
        .inbox-stat-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 1.25rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            transition: all 0.3s ease;
        }
        .inbox-stat-card:hover {
            transform: translateY(-2px);
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.15);
        }
        .inbox-stat-card .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .inbox-stat-card.unread-stat .stat-icon { background: rgba(37,211,102,0.12); color: #25d366; }
        .inbox-stat-card.confirmed-stat .stat-icon { background: rgba(46,213,115,0.12); color: #2ed573; }
        .inbox-stat-card.pending-stat .stat-icon { background: rgba(255,165,2,0.12); color: #ffa502; }
        .inbox-stat-card.edits-stat .stat-icon { background: rgba(83,189,235,0.12); color: #53bdeb; }
        .inbox-stat-card .stat-number {
            font-size: 1.6rem;
            font-weight: 700;
            font-family: 'Archivo Narrow', sans-serif;
            color: #fff;
        }
        .inbox-stat-card .stat-label {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.5);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Inbox List */
        .inbox-list-container {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .inbox-list-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .inbox-list-header h3 {
            margin: 0;
            font-family: 'Archivo Narrow', sans-serif;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,0.6);
        }

        /* Inbox Item Row */
        .inbox-item {
            display: grid;
            grid-template-columns: 44px 1.5fr 2fr 0.8fr 0.6fr 100px;
            gap: 1rem;
            align-items: center;
            padding: 1rem 1.25rem;
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.25s ease;
        }
        .inbox-item:hover {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.15);
            transform: translateY(-1px);
        }

        /* Inbox Avatar */
        .inbox-avatar {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 700;
            font-size: 0.9rem;
            flex-shrink: 0;
        }
        .inbox-avatar.unread { background: rgba(37, 211, 102, 0.15); color: #25d366; }
        .inbox-avatar.confirmed { background: rgba(46, 213, 115, 0.15); color: #2ed573; }

        /* Inbox Customer Info */
        .inbox-customer-info { min-width: 0; }
        .inbox-customer-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .inbox-customer-order {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.4);
            font-family: 'Inter', monospace;
            margin-top: 0.15rem;
        }

        /* Inbox Message / Items Preview */
        .inbox-preview {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.6);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.5;
        }
        .inbox-preview .msg-prefix {
            color: #25d366;
            font-weight: 600;
            font-size: 0.7rem;
            margin-right: 0.3rem;
        }

        /* Inbox Amount */
        .inbox-amount {
            font-size: 1.1rem;
            font-weight: 700;
            font-family: 'Archivo Narrow', sans-serif;
            color: #fff;
            text-align: right;
        }
        .inbox-pay-method {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.4);
            text-align: right;
        }

        /* Inbox Time */
        .inbox-time {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.4);
            text-align: right;
        }
        .inbox-time-relative {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.6);
            font-weight: 500;
        }
        .inbox-time-absolute {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.3);
            margin-top: 0.15rem;
        }

        /* Dual timestamp display for confirmed tab */
        .inbox-time-dual {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            min-width: 120px;
        }
        .inbox-time-block {
            padding: 0.4rem;
            background: rgba(255,255,255,0.03);
            border-radius: 6px;
            border-left: 2px solid rgba(255,255,255,0.1);
        }
        .inbox-time-block:first-child {
            border-left-color: #ffa502;
        }
        .inbox-time-block:last-child {
            border-left-color: #2ed573;
        }
        .inbox-time-label {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: rgba(255,255,255,0.5);
            margin-bottom: 0.2rem;
        }
        .inbox-time-block .inbox-time-relative {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.7);
        }
        .inbox-time-block .inbox-time-absolute {
            font-size: 0.65rem;
            color: rgba(255,255,255,0.4);
        }

        /* Inbox Actions */
        .inbox-actions {
            display: flex;
            gap: 0.4rem;
            justify-content: flex-end;
        }
        .inbox-action-btn {
            padding: 0.4rem 0.7rem;
            border-radius: 6px;
            font-size: 0.7rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        .inbox-action-btn.chat { background: #25d366; color: #000; }
        .inbox-action-btn.chat:hover { background: #128c7e; color: #fff; }
        .inbox-action-btn.wa { background: transparent; border: 1px solid #25d366; color: #25d366; }
        .inbox-action-btn.wa:hover { background: #25d366; color: #000; }
        .inbox-action-btn.mark-read { background: transparent; border: 1px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.7); }
        .inbox-action-btn.mark-read:hover { background: rgba(255,255,255,0.1); color: #fff; border-color: #fff; }

        /* Inbox Method Badge */
        .inbox-method-badge {
            font-size: 0.6rem;
            padding: 0.1rem 0.5rem;
            border-radius: 10px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            margin-left: 0.4rem;
            vertical-align: middle;
        }
        .inbox-method-badge.whatsapp { background: rgba(37,211,102,0.2); color: #25d366; border: 1px solid rgba(37,211,102,0.3); }
        .inbox-method-badge.manual { background: rgba(83,189,235,0.2); color: #53bdeb; border: 1px solid rgba(83,189,235,0.3); }

        /* Inbox Unread Count */
        .inbox-unread-count {
            font-size: 0.65rem;
            background: rgba(255,71,87,0.15);
            color: #ff4757;
            padding: 0.1rem 0.4rem;
            border-radius: 8px;
            font-weight: 700;
            margin-left: 0.4rem;
        }

        /* Inbox Date Filter Bar */
        .inbox-date-bar {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
        }
        .inbox-date-bar-label {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.5);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            margin-right: 0.25rem;
        }
        .inbox-date-bar label {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Archivo Narrow', sans-serif;
        }
        .inbox-date-bar input[type="date"] {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            color: #fff;
            padding: 0.4rem 0.6rem;
            border-radius: 8px;
            font-size: 0.8rem;
            font-family: 'Inter', sans-serif;
        }
        .inbox-date-bar input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(1);
        }
        .inbox-quick-date {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.15);
            color: rgba(255,255,255,0.5);
            padding: 0.35rem 0.75rem;
            border-radius: 8px;
            font-size: 0.7rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }
        .inbox-quick-date:hover { background: rgba(255,255,255,0.08); color: #fff; }
        .inbox-quick-date.active { background: #25d366; color: #000; border-color: #25d366; }
        .inbox-date-bar .clear-btn {
            background: transparent;
            border: 1px solid rgba(255,71,87,0.3);
            color: #ff4757;
            padding: 0.35rem 0.75rem;
            border-radius: 8px;
            font-size: 0.7rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }
        .inbox-date-bar .clear-btn:hover { background: rgba(255,71,87,0.15); }

        /* Inbox Active Date Chip */
        .inbox-active-filter-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: rgba(37,211,102,0.12);
            border: 1px solid rgba(37,211,102,0.25);
            color: #25d366;
            padding: 0.25rem 0.7rem;
            border-radius: 20px;
            font-size: 0.72rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.3px;
            margin-left: 0.5rem;
        }
        .inbox-active-filter-chip .chip-close {
            cursor: pointer;
            opacity: 0.7;
            font-size: 0.85rem;
            line-height: 1;
            transition: opacity 0.2s;
        }
        .inbox-active-filter-chip .chip-close:hover { opacity: 1; }
        .inbox-active-filter-chip .chip-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            cursor: pointer;
        }
        .inbox-active-filter-chip .chip-tag:hover { opacity: 0.8; }

        /* Inbox Filter Bar */
        .inbox-filter-bar {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
        }
        .inbox-search-input {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            color: #fff;
            padding: 0.4rem 0.7rem;
            border-radius: 8px;
            font-size: 0.8rem;
            font-family: 'Inter', sans-serif;
            width: 200px;
            outline: none;
            transition: border-color 0.2s;
        }
        .inbox-search-input:focus { border-color: rgba(37,211,102,0.5); }
        .inbox-search-input::placeholder { color: rgba(255,255,255,0.3); }
        .inbox-filter-select {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            color: #fff;
            padding: 0.4rem 0.6rem;
            border-radius: 8px;
            font-size: 0.75rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.3px;
            cursor: pointer;
            outline: none;
        }
        .inbox-filter-select option { background: #111; color: #fff; }
        .inbox-filter-spacer { flex: 1; }
        .inbox-filter-action {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.15);
            color: rgba(255,255,255,0.6);
            padding: 0.4rem 0.75rem;
            border-radius: 8px;
            font-size: 0.7rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }
        .inbox-filter-action:hover { background: rgba(255,255,255,0.08); color: #fff; }
        .inbox-filter-action.export { border-color: rgba(37,211,102,0.3); color: #25d366; }
        .inbox-filter-action.export:hover { background: rgba(37,211,102,0.12); }
        .inbox-filter-action.active { background: rgba(37,211,102,0.15); color: #25d366; border-color: rgba(37,211,102,0.3); }

        /* Inbox Item Checkbox */
        .inbox-item-checkbox-wrap {
            display: flex;
            align-items: center;
            padding-right: 0.3rem;
        }
        .inbox-item-checkbox {
            width: 16px;
            height: 16px;
            cursor: pointer;
            accent-color: #25d366;
        }

        /* Inbox Bulk Action Bar */
        .inbox-bulk-bar {
            position: sticky;
            bottom: 0;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1.5rem;
            background: rgba(10,10,10,0.95);
            border-top: 1px solid rgba(37,211,102,0.2);
            backdrop-filter: blur(10px);
            z-index: 10;
        }
        .inbox-bulk-bar #inboxSelectedCount {
            font-size: 0.8rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            color: #25d366;
            letter-spacing: 0.5px;
        }
        .inbox-bulk-btn {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            color: rgba(255,255,255,0.7);
            padding: 0.4rem 0.85rem;
            border-radius: 8px;
            font-size: 0.72rem;
            font-family: 'Archivo Narrow', sans-serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }
        .inbox-bulk-btn:hover { background: rgba(255,255,255,0.08); color: #fff; }
        .inbox-bulk-btn.export { border-color: rgba(37,211,102,0.4); color: #25d366; }
        .inbox-bulk-btn.export:hover { background: rgba(37,211,102,0.12); }
        .inbox-bulk-btn.read { border-color: rgba(83,189,235,0.4); color: #53bdeb; }
        .inbox-bulk-btn.read:hover { background: rgba(83,189,235,0.12); }
        .inbox-bulk-btn.deselect { border-color: rgba(255,71,87,0.3); color: #ff4757; }
        .inbox-bulk-btn.deselect:hover { background: rgba(255,71,87,0.1); }

        /* Confirmed-only filters visibility */
        .inbox-confirmed-filter { transition: opacity 0.2s; }
        .inbox-confirmed-filter.hidden { display: none; }
        .inbox-unread-filter.hidden { display: none; }

        /* Inbox Status Badge */
        .inbox-status {
            font-size: 0.65rem;
            padding: 0.15rem 0.45rem;
            border-radius: 4px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            display: inline-block;
            margin-top: 0.2rem;
        }
        .inbox-status.pending { background: rgba(255,165,2,0.15); color: #ffa502; }
        .inbox-status.confirmed { background: rgba(46,213,115,0.15); color: #2ed573; }
        .inbox-status.edit_details { background: rgba(83,189,235,0.15); color: #53bdeb; }
        .inbox-status.cancelled { background: rgba(255,71,87,0.15); color: #ff4757; }

        /* Inbox Empty State */
        .inbox-empty {
            text-align: center;
            padding: 5rem 2rem;
            color: rgba(255,255,255,0.3);
        }
        .inbox-empty-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.3;
        }
        .inbox-empty-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: rgba(255,255,255,0.5);
