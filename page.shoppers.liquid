        .status-pill-mini.active { background: #fff; color: #000; border-color: #fff; }

        /* Message Dot Indicator */
        .msg-indicator {
            width: 8px;
            height: 8px;
            background: #25d366;
            border-radius: 50%;
            display: inline-block;
            margin-left: 0.4rem;
